---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Link, Media } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'
import imgDesktopWallet from '@content/projects/alephium-desktop-wallet/19shots_so.png'
import imgFlatwise from '@content/projects/flatwise/flatwise-iphone-left.png'
import imgMobileWallet from '@content/projects/alephium-mobile-wallet/63shots_so.png'

const posts = await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV)
posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
const latestPosts = posts.slice(0, 3)
---

<DefaultLayout title="nop33">
  <section class="my-24">
    <div class="container grid grid-cols-1 items-center gap-12 md:grid-cols-2">
      <div>
        <h1 class="text-center text-6xl md:text-left">
          nop33 <span class="text-neutral-500 dark:text-neutral-700">on the web</span>
        </h1>
        <p class="text-center text-5xl md:text-left">
          Ilias Trichopoulos <span class="text-neutral-500 dark:text-neutral-700">irl</span>
        </p>
        <p class="mt-4 text-center text-2xl md:text-left dark:text-neutral-500">
          Software engineer with focus on <span class="font-bold">frontend</span>,<br /> minimalist, and life-long learner.
        </p>
      </div>
      <Media src="/notion-avatar-v2.png" class="mx-auto max-w-sm" />
    </div>
  </section>
  <section class="my-32">
    <div class="container">
      <h2 class="mb-6 text-center text-6xl md:text-left">About me</h2>
      <p class="text-center text-2xl font-bold md:text-left dark:text-neutral-500">I went online in 2001.</p>
      <p class="text-center text-2xl md:text-left dark:text-neutral-500">
        Since my early days on the web, I've grown into building alongside talented designers and engineers who have
        raised my standards of what building good software means. A journey that eventually took me to work at the web's
        birthplace, <Link href="/about-ilias">CERN</Link>.
      </p>
    </div>
  </section>

  <section class="my-48 bg-gray-50 py-24 dark:bg-gray-900">
    <div class="container">
      <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
        <div>
          <div
            class="mb-4 inline-block rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-800 dark:bg-green-900 dark:text-green-100"
          >
            Current Focus
          </div>
          <h2 class="mb-6 text-5xl">Frontend Lead @Alephium</h2>
          <p class="mb-8 text-2xl dark:text-neutral-500">
            Core maintainer and frontend lead for Alephium's entire user-facing surface - self-custody mobile & desktop
            wallets, blockchain explorer, and bridging infrastructure.
          </p>
          <Link href="/experience/alephium" isButton variant="primary" animateOnHover animationType="nudge">
            Read the Alephium deep dive
            <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
          </Link>
        </div>
        <div class="hidden md:block">
          <div class="grid grid-cols-1 gap-4">
            <a
              href="/portfolio/alephium-desktop-wallet"
              class="group block rounded-xl bg-white p-6 !text-current no-underline shadow-sm transition-colors hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700"
              style="text-decoration: none;"
            >
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-xl font-bold">
                    Desktop Wallet <span class="text-sm font-normal text-gray-500 dark:text-gray-400">(Electron)</span>
                  </h3>
                  <p class="mt-1 text-gray-500 dark:text-gray-400">Owner, Core Maintainer</p>
                </div>
                <Icon
                  aria-hidden="true"
                  name="lucide:arrow-right"
                  size="1.5rem"
                  class="text-gray-400 transition-colors group-hover:text-gray-900 dark:group-hover:text-white"
                />
              </div>
            </a>
            <a
              href="/portfolio/alephium-mobile-wallet"
              class="group block rounded-xl bg-white p-6 !text-current no-underline shadow-sm transition-colors hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700"
              style="text-decoration: none;"
            >
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-xl font-bold">
                    Mobile Wallet <span class="text-sm font-normal text-gray-500 dark:text-gray-400"
                      >(React Native / Expo)</span
                    >
                  </h3>
                  <p class="mt-1 text-gray-500 dark:text-gray-400">Co-creator, Owner, Core Maintainer</p>
                </div>
                <Icon
                  aria-hidden="true"
                  name="lucide:arrow-right"
                  size="1.5rem"
                  class="text-gray-400 transition-colors group-hover:text-gray-900 dark:group-hover:text-white"
                />
              </div>
            </a>
            <a
              href="https://powfi.alephium.org"
              target="_blank"
              rel="noopener noreferrer"
              data-umami-event="project-link-click"
              data-umami-event-project="Powfi"
              data-umami-event-type="live"
              class="group block rounded-xl bg-white p-6 !text-current no-underline shadow-sm transition-colors hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700"
              style="text-decoration: none;"
            >
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-xl font-bold">
                    Powfi <span class="text-sm font-normal text-gray-500 dark:text-gray-400">(Next.js)</span>
                  </h3>
                  <p class="mt-1 text-gray-500 dark:text-gray-400">Owner, Core Maintainer</p>
                </div>
                <Icon
                  aria-hidden="true"
                  name="lucide:arrow-up-right"
                  size="1.5rem"
                  class="text-gray-400 transition-colors group-hover:text-gray-900 dark:group-hover:text-white"
                />
              </div>
            </a>
            <a
              href="https://github.com/alephium/alephium-frontend"
              target="_blank"
              rel="noopener noreferrer"
              data-umami-event="project-link-click"
              data-umami-event-project="Frontend Monorepo"
              data-umami-event-type="github"
              class="group block rounded-xl bg-white p-6 !text-current no-underline shadow-sm transition-colors hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700"
              style="text-decoration: none;"
            >
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-xl font-bold">
                    Frontend Monorepo <span class="text-sm font-normal text-gray-500 dark:text-gray-400"
                      >(pnpm / Turborepo)</span
                    >
                  </h3>
                  <p class="mt-1 text-gray-500 dark:text-gray-400">Creator, Core Maintainer</p>
                </div>
                <Icon
                  aria-hidden="true"
                  name="lucide:arrow-up-right"
                  size="1.5rem"
                  class="text-gray-400 transition-colors group-hover:text-gray-900 dark:group-hover:text-white"
                />
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="my-48">
    <div class="container">
      <h2 class="mb-6 text-center text-6xl md:text-left">Projects</h2>
      <p class="mb-12 text-center text-2xl md:text-left dark:text-neutral-500">
        There is always a project in the works, whether professional or personal, and an endless list of ideas. Here are
        some of the projects I've spent most of my time on and am most proud of.
      </p>
      <div>
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
          <Media src={imgDesktopWallet.src} />
          <div class="space-content md:mt-24">
            <h3 class="md:text-left">Alephium Desktop Wallet</h3>
            <p class="text-2xl md:text-left dark:text-neutral-500">
              Electron React app for securely storing and managing assets on the Alephium blockchain.
            </p>
            <Link
              href="/portfolio/alephium-desktop-wallet"
              isButton
              variant="outlined"
              animateOnHover
              animationType="nudge"
            >
              View project
              <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
            </Link>
          </div>
        </div>
      </div>

      <div class="mt-48 md:mt-24">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
          <Media src={imgFlatwise.src} class="order-1 md:order-2 md:col-span-1" />
          <div class="space-content order-2 md:order-1 md:col-span-2 md:mt-24">
            <h3 class="md:text-left">Flatwise</h3>
            <p class="text-2xl md:text-left dark:text-neutral-500">
              A web app that fairly redistributes furniture costs when flatmates move in or out, using depreciation
              instead of an awkward conversation. Built with Vue.js & Material UI. Used in a real Zurich flatshare since
              2019.
            </p>
            <Link href="/portfolio/flatwise" isButton variant="outlined" animateOnHover animationType="nudge">
              View project
              <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
            </Link>
          </div>
        </div>
      </div>
      <div class="mt-48 md:mt-24">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
          <Media src={imgMobileWallet.src} />
          <div class="space-content md:mt-24">
            <h3 class="md:text-left">Alephium Mobile Wallet</h3>
            <p class="text-2xl md:text-left dark:text-neutral-500">
              React Native app completing the Alephium Desktop Wallet, built for everyday use.
            </p>
            <Link
              href="/portfolio/alephium-mobile-wallet"
              isButton
              variant="outlined"
              animateOnHover
              animationType="nudge"
            >
              View project
              <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
            </Link>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="my-64">
    <div class="container">
      <h2 class="mb-6 text-center text-6xl md:text-left">Blog</h2>
      <p class="mb-12 text-center text-2xl md:text-left dark:text-neutral-500">
        Writing about the things I learn along the way.
      </p>
      <ul class="space-y-8">
        {
          latestPosts.map((post) => (
            <li>
              <h3 class="md:text-left">
                <Link href={`/blog/${post.id}`}>{post.data.title}</Link>
              </h3>
              <p class="mt-2 text-2xl md:text-left dark:text-neutral-500">{post.data.description}</p>
            </li>
          ))
        }
      </ul>
      <div class="mt-12">
        <Link href="/blog/" isButton variant="outlined" animateOnHover animationType="nudge">
          Read all posts
          <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
        </Link>
      </div>
    </div>
  </section>
</DefaultLayout>
