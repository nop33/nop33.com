---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Link } from 'accessible-astro-components'
import Experience from '@components/Experience.astro'
import KeyStrengths from '@components/KeyStrengths.astro'
import Testimonials from '@components/Testimonials.astro'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="Experience - Ilias Trichopoulos">
  <section class="hero my-24">
    <div class="narrow container">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <h1 class="text-center text-6xl md:text-left">Experience</h1>
        <p class="text-center text-xl text-gray-600 md:text-left md:text-2xl dark:text-gray-300">
          My professional journey building software for startups, scale-ups, and the web's birthplace.
        </p>
      </div>
    </div>
  </section>

  <section class="my-16">
    <div class="narrow container">
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-8 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <span class="flex h-3 w-3 shrink-0 rounded-full bg-green-500"></span>
            <h2 class="text-2xl font-bold tracking-wide text-gray-900 uppercase dark:text-white">Current Focus</h2>
          </div>
          <h3 class="text-3xl font-bold">Frontend Lead @Alephium</h3>
          <p class="text-lg text-gray-600 dark:text-gray-300">
            Since 2021, I've been the core maintainer and frontend lead for Alephium's entire user-facing surface,
            managing self-custody wallets across mobile and desktop, the blockchain explorer, and bridging
            infrastructure.
          </p>
          <div class="mt-4">
            <Link href="/experience/alephium" isButton variant="primary" animateOnHover animationType="nudge">
              Read the Alephium deep dive
              <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
            </Link>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="my-24">
    <div class="narrow container">
      <h2 class="mb-12 border-b pb-4 text-4xl font-bold">Work History</h2>
      <Experience />
    </div>
  </section>

  <section class="my-24">
    <div class="container">
      <h2 class="mb-12 text-4xl font-bold">Key Strengths</h2>
      <KeyStrengths />
    </div>
  </section>

  <section class="my-24">
    <div class="container">
      <h2 class="mb-4 text-4xl font-bold">What people say</h2>
      <p class="mb-12 text-gray-600 dark:text-gray-400">Recommendations from clients and colleagues on LinkedIn.</p>
      <Testimonials />
    </div>
  </section>
</DefaultLayout>
