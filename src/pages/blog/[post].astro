---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Image } from 'astro:assets'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV)

  return posts.map((post) => ({
    params: { post: post.id },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content, remarkPluginFrontmatter } = await render(post)

const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const subtitle = `${formattedDate} · ${remarkPluginFrontmatter.minutesRead}`
---

<DefaultLayout
  title={post.data.title}
  description={post.data.description}
  url={`/blog/${post.id}`}
  image={post.data.featuredImage?.src?.replace(/^\//, '')}
  imageWidth={post.data.featuredImage?.width}
  imageHeight={post.data.featuredImage?.height}
>
  <PageHeader title={post.data.title} subtitle={subtitle} bgType="bordered" />
  {
    post.data.featuredImage && (
      <div class="container my-12">
        <Image src={post.data.featuredImage} alt="" width={1200} height={630} class="w-full rounded-lg object-cover" />
      </div>
    )
  }
  <section class="my-12">
    <div class="blog-post narrow space-content container">
      <Content />
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .narrow {
    margin-inline: auto;
    max-width: 65ch;
  }

  // Title width is handled by PageHeader (it only splits into two columns when
  // a side image is present). Here we just let long titles fill each line to
  // the edge, adjusting only the last line to avoid an orphan word.
  .page-header h1 {
    text-wrap: pretty;
  }

  // Smaller in-article headings for blog posts (the global scale is sized for page titles).
  .blog-post {
    h2 {
      font-size: var(--font-size-3);
      line-height: var(--font-size-4);
    }

    h3 {
      font-size: var(--font-size-2);
      line-height: var(--font-size-3);
    }

    blockquote {
      margin-block: var(--space-m);
      padding-block: var(--space-3xs);
      padding-inline-start: var(--space-s);
      border-inline-start: 4px solid light-dark(var(--color-primary-400), var(--color-primary-300));
      color: light-dark(var(--color-neutral-700), var(--color-neutral-300));
      font-style: italic;

      > :first-child {
        margin-block-start: 0;
      }

      > :last-child {
        margin-block-end: 0;
      }
    }
  }
</style>
