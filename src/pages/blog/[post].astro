---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Image } from 'astro:assets'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV)

  return posts.map((post) => ({
    params: { post: post.id },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<DefaultLayout
  title={post.data.title}
  description={post.data.description}
  url={`/blog/${post.id}`}
  image={post.data.featuredImage?.src?.replace(/^\//, '')}
  imageWidth={post.data.featuredImage?.width}
  imageHeight={post.data.featuredImage?.height}
>
  <PageHeader
    class={post.data.featuredImage ? undefined : 'no-featured-image'}
    title={post.data.title}
    subtitle={formattedDate}
    bgType="bordered"
  />
  {
    post.data.featuredImage && (
      <div class="container my-12">
        <Image src={post.data.featuredImage} alt="" width={1200} height={630} class="w-full rounded-lg object-cover" />
      </div>
    )
  }
  <section class="my-12">
    <div class="blog-post narrow space-content container">
      <Content />
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .narrow {
    margin-inline: auto;
    max-width: 65ch;
  }

  // When a post has no featured image, let the title span the header's full
  // width (the grid otherwise reserves a second column for the image) and
  // balance its line lengths.
  .page-header.no-featured-image {
    .grid > div {
      grid-column: 1 / -1;
    }

    h1 {
      text-wrap: balance;
    }
  }

  // Smaller in-article headings for blog posts (the global scale is sized for page titles).
  .blog-post {
    h2 {
      font-size: var(--font-size-3);
      line-height: var(--font-size-4);
    }

    h3 {
      font-size: var(--font-size-2);
      line-height: var(--font-size-3);
    }
  }
</style>
