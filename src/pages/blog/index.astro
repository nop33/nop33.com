---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV)

posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<DefaultLayout title="Blog" description="Articles about web development, performance, and open source.">
  <PageHeader title="Blog" subtitle="Articles about web development, performance, and open source." bgType="bordered" />

  <section class="my-12">
    <div class="container">
      <ul class="mx-auto max-w-2xl divide-y divide-[var(--border-color-subtle)]">
        {
          posts.map((post) => (
            <li class="post">
              <article class="py-8">
                <time class="text-sm text-neutral-600 dark:text-neutral-400" datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
                <h2 class="mt-1 mb-2 text-2xl font-bold">
                  <a href={'/blog/' + post.id}>{post.data.title}</a>
                </h2>
                <p>{post.data.description}</p>
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  .post a {
    color: inherit;
    text-decoration: none;

    &:hover {
      text-decoration: underline;
      text-decoration-thickness: 2px;
      text-underline-offset: 0.2em;
    }
  }
</style>
