---
const strengths = {
  tech: [
    'React',
    'Typescript',
    'React Native',
    'Expo / EAS',
    'Next.js',
    'Tailwind CSS',
    'SCSS',
    'Node.js',
    'Git',
    'Electron',
    'TanStack Query',
    'Redux',
    'Web3',
    'GitHub Actions',
    'Monorepos',
  ],
  work: [
    'Large-scale System Design',
    'Applied security',
    'Technical leadership & mentoring',
    'Performance profiling & optimization',
    'Testing & quality engineering',
    'Accessibility (WCAG)',
    'Pixel-perfect design implementation',
    'Project ownership',
    'Execution precision',
    'Strong understanding of DeFi UX',
  ],
  human: [
    'Clear communicator',
    'Reliable',
    'Curious',
    'Organized',
    'Eye for details',
    'Always here to help',
    'Good mood transmitter',
  ],
}
---

<div class="grid grid-cols-1 gap-8 md:grid-cols-3">
  <div class="flex flex-col gap-4">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Tech</h3>
    <ul class="flex flex-wrap gap-2">
      {
        strengths.tech.map((item) => (
          <li class="rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800 dark:bg-gray-800 dark:text-gray-200">
            {item}
          </li>
        ))
      }
    </ul>
  </div>

  <div class="flex flex-col gap-4">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Work</h3>
    <ul class="flex flex-col gap-2">
      {
        strengths.work.map((item) => (
          <li class="flex items-start text-gray-600 dark:text-gray-300">
            <span class="mr-2 text-sky-500">•</span>
            {item}
          </li>
        ))
      }
    </ul>
  </div>

  <div class="flex flex-col gap-4">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Human</h3>
    <ul class="flex flex-col gap-2">
      {
        strengths.human.map((item) => (
          <li class="flex items-start text-gray-600 dark:text-gray-300">
            <span class="mr-2 text-sky-500">•</span>
            {item}
          </li>
        ))
      }
    </ul>
  </div>
</div>
