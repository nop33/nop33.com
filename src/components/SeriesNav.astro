---
/**
 * SeriesNav
 *
 * A dev.to-style "N Part Series" table of contents, rendered at the top of every
 * post that belongs to a multi-part series. It reads every post in the `blog`
 * collection that shares the given `series` id, orders them by `seriesOrder`,
 * and marks the current one.
 *
 * Drafts are included only in `npm run dev` (same rule as the rest of the site),
 * so the list grows automatically as each part is published.
 *
 * Usage from an MDX post:
 *   import SeriesNav from '@components/SeriesNav.astro'
 *   <SeriesNav series="tanstack-query-case-study" current={2} />
 */
import { getCollection } from 'astro:content'

interface Props {
  /** The series id shared by every post in the series (matches frontmatter `series`). */
  series: string
  /** The `seriesOrder` of the post this nav is rendered on, used to mark the active row. */
  current: number
}

const { series, current } = Astro.props

// Human-readable series names, keyed by series id.
const SERIES_NAMES: Record<string, string> = {
  'tanstack-query-case-study': 'A TanStack Query Case Study',
}

const parts = (await getCollection('blog', ({ data }) => !data.draft || import.meta.env.DEV))
  .filter((post) => post.data.series === series)
  .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))

const seriesName = SERIES_NAMES[series] ?? 'Series'
---

<nav class="series-nav" aria-label={`${seriesName}, ${parts.length} part series`}>
  <p class="series-nav__heading">
    {seriesName} <span class="series-nav__count">({parts.length} Part Series)</span>
  </p>
  <ol class="series-nav__list">
    {
      parts.map((part) => {
        const isCurrent = part.data.seriesOrder === current
        const label = part.data.seriesLabel ?? part.data.title
        return (
          <li class:list={['series-nav__item', { 'is-current': isCurrent }]}>
            {isCurrent ? (
              <span class="series-nav__row" aria-current="step">
                <span class="series-nav__badge" aria-hidden="true">
                  {part.data.seriesOrder}
                </span>
                <span class="series-nav__label">{label}</span>
              </span>
            ) : (
              <a class="series-nav__row" href={`/blog/${part.id}`}>
                <span class="series-nav__badge" aria-hidden="true">
                  {part.data.seriesOrder}
                </span>
                <span class="series-nav__label">{label}</span>
              </a>
            )}
          </li>
        )
      })
    }
  </ol>
</nav>

<style lang="scss">
  .series-nav {
    margin-block: 2.5rem;
    border: 1px solid var(--border-color-subtle);
    border-radius: 12px;
    background: light-dark(var(--color-neutral-100), var(--color-neutral-800));
  }

  .series-nav__heading {
    margin: 0;
    padding: 1rem 1.25rem;
    border-block-end: 1px solid var(--border-color-subtle);
    color: var(--link-color);
    font-size: var(--font-size-1);
    font-weight: 700;
    line-height: 1.3;
  }

  .series-nav__count {
    color: light-dark(var(--color-neutral-600), var(--color-neutral-400));
    font-weight: 600;
  }

  .series-nav__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .series-nav__item + .series-nav__item {
    border-block-start: 1px solid var(--border-color-subtle);
  }

  .series-nav__row {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 1.25rem;
    color: light-dark(var(--color-neutral-700), var(--color-neutral-400));
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  a.series-nav__row:hover {
    background: light-dark(var(--color-neutral-200), var(--color-neutral-700));
    color: var(--foreground-color);
  }

  .series-nav__badge {
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: light-dark(var(--color-neutral-300), var(--color-neutral-700));
    color: light-dark(var(--color-neutral-700), var(--color-neutral-300));
    font-size: 0.85rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .series-nav__label {
    font-size: var(--font-size-0);
    line-height: 1.35;
  }

  // The active part: filled badge and full-strength, bolder label.
  .series-nav__item.is-current {
    .series-nav__badge {
      background: var(--link-color);
      color: light-dark(var(--color-neutral-100), var(--color-neutral-900));
    }

    .series-nav__label {
      color: var(--foreground-color);
      font-weight: 700;
    }
  }
</style>
