---
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * CallToAction Component
 *
 * @description A prominent call-to-action section with a title and link
 */
interface Props {
  /**
   * The title text to display
   * @default "Get this theme on GitHub"
   */
  title?: string
  /**
   * The URL the button should link to
   * @default "https://github.com/incluud/accessible-astro-starter"
   */
  link?: string
  /**
   * The text to display on the button
   * @default "Get Started"
   */
  linkText?: string
}

const { title = "Let's build something together!" } = Astro.props
---

<section class="call-to-action-section">
  <div class="container">
    <div
      class="call-to-action my-16 flex flex-col items-center gap-12 rounded-xl px-6 py-16 md:my-32 md:px-24 md:py-20"
    >
      <Heading level="h2" class="text-center">{title}</Heading>
      <p class="text-center text-xl md:text-2xl dark:text-neutral-500">
        Feel free to reach out if you have any questions, want to collaborate, or just want to connect.
      </p>
      <div class="flex flex-col items-center gap-4 md:flex-row">
        <Link
          href="https://www.linkedin.com/in/iliastrichopoulos/"
          isButton
          size="lg"
          variant="outlined"
          animateOnHover
          animationType="nudge"
          rel="noopener noreferrer"
          target="_blank"
          data-umami-event="linkedin-click"
          data-umami-event-location="cta"
        >
          LinkedIn
          <Icon aria-hidden="true" name="lucide:linkedin" size="1.5rem" />
        </Link>
        <Link
          href="https://github.com/nop33"
          isButton
          size="lg"
          variant="outlined"
          animateOnHover
          animationType="nudge"
          rel="noopener noreferrer"
          target="_blank"
          data-umami-event="github-click"
          data-umami-event-location="cta"
        >
          GitHub
          <Icon aria-hidden="true" name="lucide:github" size="1.5rem" />
        </Link>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../assets/scss/base/mixins' as *;

  .call-to-action-section {
    border-top: 1px solid var(--border-color-subtle);
  }

  .call-to-action {
    position: relative;
    // background-image: linear-gradient(
    //   315deg,
    //   light-dark(var(--color-primary-100), var(--color-secondary-100)) 25%,
    //   light-dark(var(--color-secondary-100), var(--color-primary-200))
    // );
    // color: var(--color-neutral-900);
  }
</style>
